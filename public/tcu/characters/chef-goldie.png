<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="64" height="64">
  <rect width="64" height="64" rx="12" fill="#78350f"/>
  <!-- Face -->
  <circle cx="32" cy="30" r="16" fill="#fcd34d"/>
  <!-- Chef hat -->
  <ellipse cx="32" cy="19" rx="12" ry="4" fill="#f59e0b"/>
  <ellipse cx="32" cy="13" rx="8" ry="7" fill="#fbbf24"/>
  <!-- Eyes -->
  <circle cx="27" cy="29" r="2.5" fill="#1e1b4b"/>
  <circle cx="37" cy="29" r="2.5" fill="#1e1b4b"/>
  <circle cx="28" cy="28" r="1" fill="white"/>
  <circle cx="38" cy="28" r="1" fill="white"/>
  <!-- Smile -->
  <path d="M26 35 Q32 40 38 35" stroke="#92400e" stroke-width="2" fill="none" stroke-linecap="round"/>
  <!-- Gold coin badge -->
  <circle cx="50" cy="50" r="10" fill="#f59e0b" stroke="#d97706" stroke-width="1.5"/>
  <text x="50" y="54" font-family="system-ui" font-size="9" font-weight="900" text-anchor="middle" fill="#78350f">$</text>
</svg>