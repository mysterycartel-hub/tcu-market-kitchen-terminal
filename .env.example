# ── REQUIRED FOR LIVE SUPABASE ────────────────────────────────────────────────
# Without these, the app runs in full demo mode (no auth, no saved journal/trades).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OPTIONAL UPGRADES ─────────────────────────────────────────────────────────
# Live AI coaching — omit to use built-in demo analysis
OPENAI_API_KEY=

# Live market data — omit to use built-in demo candles
NEXT_PUBLIC_MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=

# Supabase service role — only needed for server-side admin/webhook actions
SUPABASE_SERVICE_ROLE_KEY=

# Stripe subscriptions — only needed if selling paid plans
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Beehiiv email capture — omit to skip newsletter signup (does not block the app)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Vercel Blob — only needed for chart screenshot uploads
BLOB_READ_WRITE_TOKEN=
